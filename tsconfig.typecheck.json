{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "rootDir": ".",
    "types": ["node", "react", "react-dom"],
    "outDir": "./dist-typecheck"
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.ts",
    "website/**/*.ts",
    "website/**/*.tsx"
  ]
}
